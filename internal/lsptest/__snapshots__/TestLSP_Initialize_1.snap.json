{
 "capabilities": {
  "codeActionProvider": {
   "codeActionKinds": [
    "quickfix",
    "quickfix.suppress.tally",
    "source.fixAll.tally"
   ]
  },
  "diagnosticProvider": {
   "identifier": "tally",
   "interFileDependencies": false,
   "workspaceDiagnostics": false
  },
  "documentFormattingProvider": true,
  "executeCommandProvider": {
   "commands": [
    "tally.applyAllFixes",
    "tally.openRuleDoc"
   ]
  },
  "semanticTokensProvider": {
   "full": true,
   "legend": {
    "tokenModifiers": [
     "declaration",
     "readonly",
     "documentation",
     "defaultLibrary"
    ],
    "tokenTypes": [
     "keyword",
     "comment",
     "string",
     "number",
     "operator",
     "variable",
     "parameter",
     "property",
     "function"
    ]
   },
   "range": true
  },
  "textDocumentSync": {
   "change": 1,
   "openClose": true,
   "save": {
    "includeText": true
   }
  }
 },
 "serverInfo": {
  "name": "tally",
  "version": "<Any value>"
 }
}