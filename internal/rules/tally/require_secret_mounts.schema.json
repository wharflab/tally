{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tally.wharflab.com/rules/tally/require_secret_mounts.schema.json",
  "title": "tally/require-secret-mounts rule config",
  "description": "Configuration options for the tally/require-secret-mounts rule.",
  "type": "object",
  "properties": {
    "severity": { "$ref": "../rule-config.schema.json#/$defs/severity" },
    "fix": { "$ref": "../rule-config.schema.json#/$defs/fix" },
    "exclude": { "$ref": "../rule-config.schema.json#/$defs/exclude" },
    "commands": {
      "type": "object",
      "description": "Map of command names to required secret mount specifications.",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Required secret ID for the --mount flag."
          },
          "target": {
            "type": "string",
            "description": "Required target path where the secret is mounted."
          }
        },
        "required": ["id", "target"],
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "severity": "warning",
      "commands": {
        "pip": { "id": "pipconf", "target": "/root/.config/pip/pip.conf" },
        "npm": { "id": "npmrc", "target": "/root/.npmrc" }
      }
    }
  ]
}
