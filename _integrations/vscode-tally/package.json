{
  "name": "tally",
  "displayName": "Tally",
  "version": "0.0.0",
  "description": "BuildKit-native Dockerfile/Containerfile linter + formatter with auto-fix (powered by tally)",
  "categories": [
    "Formatters",
    "Linters"
  ],
  "keywords": [
    "BuildKit",
    "Containerfile",
    "Docker",
    "Dockerfile",
    "Podman",
    "autofix",
    "formatter",
    "linter",
    "security"
  ],
  "license": "GPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/wharflab/tally"
  },
  "publisher": "wharflab",
  "homepage": "https://tally.wharflab.com/",
  "main": "./dist/extension.cjs",
  "scripts": {
    "postinstall": "cp node_modules/vscode-python-envs/src/api.ts src/vendor/pythonEnvsApi.d.ts",
    "compile": "bun build src/extension.ts --outfile=dist/extension.cjs --format=cjs --target=node --external=vscode --sourcemap=inline",
    "typecheck": "tsgo",
    "lint": "oxlint --type-aware ./src",
    "format": "oxfmt --write src test",
    "format:check": "oxfmt --check src test",
    "test:e2e": "bun test test/e2e/*.test.ts",
    "prevsce:package": "cp ../../LICENSE . && bun run compile",
    "vsce:package": "bunx @vscode/vsce package --no-dependencies"
  },
  "dependencies": {
    "semver": "^7.7.4",
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/bun": "1.3.12",
    "@types/node": "25.6.0",
    "@types/semver": "7.7.1",
    "@types/vscode": "1.106.0",
    "@typescript/native-preview": "7.0.0-dev.20260420.1",
    "@vscode/test-electron": "2.5.2",
    "@vscode/vsce": "3.9.1",
    "exponential-backoff": "3.1.3",
    "oxfmt": "0.46.0",
    "oxlint": "1.60.0",
    "oxlint-tsgolint": "0.21.1",
    "vscode-python-envs": "github:microsoft/vscode-python-environments#v1.28.0"
  },
  "contributes": {
    "commands": [
      {
        "command": "tally.restartServer",
        "title": "Tally: Restart server"
      },
      {
        "command": "tally.showOutput",
        "title": "Tally: Show output"
      },
      {
        "command": "tally.showLspTrace",
        "title": "Tally: Show LSP trace"
      },
      {
        "command": "tally.applyAllFixes",
        "title": "Tally: Fix all auto-fixable issues"
      },
      {
        "command": "tally.configureDefaultFormatterForDockerfile",
        "title": "Tally: Configure as default formatter for Dockerfile"
      }
    ],
    "configurationDefaults": {
      "[dockerfile]": {
        "editor.semanticHighlighting.enabled": true,
        "editor.tabSize": 1,
        "editor.insertSpaces": false,
        "files.eol": "\n"
      },
      "hadolint.maxNumberOfProblems": -1,
      "docker.languageserver.diagnostics.deprecatedMaintainer": "ignore",
      "docker.languageserver.diagnostics.directiveCasing": "ignore",
      "docker.languageserver.diagnostics.emptyContinuationLine": "ignore",
      "docker.languageserver.diagnostics.instructionCasing": "ignore",
      "docker.languageserver.diagnostics.instructionCmdMultiple": "ignore",
      "docker.languageserver.diagnostics.instructionEntrypointMultiple": "ignore",
      "docker.languageserver.diagnostics.instructionHealthcheckMultiple": "ignore",
      "docker.languageserver.diagnostics.instructionJSONInSingleQuotes": "ignore",
      "docker.languageserver.diagnostics.instructionWorkdirRelative": "ignore"
    },
    "configuration": {
      "title": "Tally",
      "properties": {
        "tally.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable the Tally language server."
        },
        "tally.path": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Explicit paths to a `tally` executable. First existing path wins."
        },
        "tally.importStrategy": {
          "type": "string",
          "default": "fromEnvironment",
          "enum": [
            "fromEnvironment",
            "useBundled"
          ],
          "description": "Where to resolve the `tally` binary from."
        },
        "tally.configuration": {
          "type": [
            "object",
            "null"
          ],
          "default": null,
          "description": "Inline configuration override (TOML-like object)."
        },
        "tally.configurationPreference": {
          "type": "string",
          "default": "editorFirst",
          "enum": [
            "editorFirst",
            "filesystemFirst",
            "editorOnly"
          ],
          "description": "How to merge VS Code settings with `.tally.toml` / `tally.toml`."
        },
        "tally.fixUnsafe": {
          "type": "boolean",
          "default": false,
          "description": "Allow manual 'Fix all' command to apply unsafe fixes."
        },
        "tally.codeAction.suppressRule.enable": {
          "type": "boolean",
          "default": true,
          "description": "Show 'Suppress rule' code actions that insert # tally ignore= directives."
        },
        "tally.codeAction.showDocumentation.enable": {
          "type": "boolean",
          "default": true,
          "description": "Show 'Show documentation' code actions to open rule docs in a browser."
        },
        "tally.fixAll.mode": {
          "type": "string",
          "default": "all",
          "enum": [
            "all",
            "problems"
          ],
          "enumDescriptions": [
            "Iteratively re-lint and fix until no more auto-fixable issues remain (up to 10 passes).",
            "Apply pre-computed fixes in a single pass (faster, but may miss cascading fixes)."
          ],
          "description": "Strategy for 'Fix all' and source.fixAll.tally code actions."
        },
        "tally.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Trace communication between VS Code and the Tally language server."
        }
      }
    },
    "semanticTokenScopes": [
      {
        "language": "dockerfile",
        "scopes": {
          "keyword": [
            "keyword.other.special-method.from.dockerfile",
            "keyword.other.special-method.as.dockerfile",
            "keyword.other.special-method.dockerfile",
            "keyword.control.onbuild.dockerfile",
            "keyword.control.heredoc-token.shell.dockerfile",
            "keyword.control.shell.dockerfile",
            "keyword.control.dockerfile",
            "keyword.control"
          ],
          "comment.documentation": [
            "comment.line.number-sign.dockerfile",
            "comment.line.number-sign.shell.dockerfile",
            "comment.line.number-sign",
            "comment"
          ],
          "comment": [
            "comment.line.number-sign.dockerfile",
            "comment.line.number-sign.shell.dockerfile",
            "comment.line.number-sign",
            "comment"
          ],
          "string": [
            "string.quoted.double.dockerfile",
            "string.quoted.single.dockerfile",
            "string.unquoted.dockerfile",
            "string.unquoted.heredoc.shell.dockerfile",
            "string"
          ],
          "number": [
            "constant.numeric.version.dockerfile",
            "constant.numeric.dockerfile",
            "constant.numeric"
          ],
          "operator": [
            "keyword.operator.assignment.dockerfile",
            "keyword.operator.assignment.shell.dockerfile",
            "keyword.operator.heredoc.shell.dockerfile",
            "keyword.operator.redirect.shell.dockerfile",
            "keyword.operator.pipe.shell.dockerfile",
            "keyword.operator.logical.shell.dockerfile",
            "keyword.operator.dockerfile",
            "keyword.operator"
          ],
          "variable": [
            "variable.other.dockerfile",
            "variable.other.normal.shell.dockerfile",
            "variable.other.assignment.dockerfile",
            "variable.other.readwrite.dockerfile",
            "variable.other.readwrite",
            "variable"
          ],
          "variable.declaration": [
            "entity.name.image.stage.dockerfile",
            "variable.other.assignment.dockerfile",
            "variable.other.constant.dockerfile",
            "variable.other.constant",
            "variable"
          ],
          "parameter": [
            "variable.parameter.dockerfile",
            "variable.parameter"
          ],
          "property": [
            "variable.other.property.dockerfile",
            "variable.other.property"
          ],
          "property.readonly": [
            "variable.other.constant.property.dockerfile",
            "variable.other.constant.property"
          ],
          "function": [
            "support.function.builtin.shell.dockerfile",
            "entity.name.function.dockerfile",
            "entity.name.function",
            "support.function"
          ]
        }
      }
    ]
  },
  "activationEvents": [
    "onLanguage:dockerfile",
    "workspaceContains:.tally.toml",
    "workspaceContains:Containerfile*",
    "workspaceContains:Dockerfile*",
    "workspaceContains:tally.toml"
  ],
  "icon": "assets/logo.png",
  "engines": {
    "vscode": "^1.106.0"
  }
}