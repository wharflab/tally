# Handle line endings automatically for files detected as text
* text=auto

# Ensure snapshot files always have LF line endings (for cross-platform testing)
**/testdata/** text eol=lf
**/__snapshots__/** text eol=lf linguist-vendored
*.snap.json text eol=lf
*.snap.txt text eol=lf
*.snap.md text eol=lf

# Shell scripts always LF
*.sh text eol=lf

# Source and config files always LF
*.go text eol=lf
go.mod text eol=lf
go.sum text eol=lf
*.md text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.toml text eol=lf
Dockerfile* text eol=lf
*.Dockerfile text eol=lf
.gitattributes text eol=lf
Makefile text eol=lf

# Windows batch files always CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# WASM
# internal/shellcheck/wasm/shellcheck.wasm is built on demand by
# `make shellcheck-wasm` (see _tools/shellcheck-wasm/) and is .gitignored.
# CI restores it from actions/cache keyed on the pinned upstream versions.
*.wasm linguist-detectable=true
*.wasm linguist-documentation=false
*.wasm linguist-language=WebAssembly

# Generated files
internal/lsp/protocol/lsp_generated.go linguist-generated=true
internal/lsp/protocol/doc.go linguist-generated=true
internal/schemas/registry_gen.go linguist-generated=true
internal/schemas/generated/**/*.gen.go linguist-generated=true
internal/rules/*/index.schema.json linguist-generated=true
schema.json linguist-generated=true
# exclude fixtures and snapshots from statistics
internal/integration/testdata/** linguist-vendored
